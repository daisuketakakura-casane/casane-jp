---
const instagramWorks = "https://www.instagram.com/daisuke_takakura/";
const instagramDaily =
  "https://www.instagram.com/daisuke_takakura_daily/";
const xUrl = "https://x.com/schrodinger678";
const portfolioUrl = "/pdf/portfolio2026.pdf";
const email = "takakura@casane.jp";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />

    <meta
      name="viewport"
      content="width=device-width, initial-scale=1"
    />

    <title>casane by Daisuke Takakura</title>

    <meta
      name="description"
      content="Official website of Daisuke Takakura. Website under reconstruction."
    />

    <link
      rel="stylesheet"
      href="https://use.typekit.net/ydk6kqa.css"
    />

    <link
      rel="icon"
      href="/favicon.svg"
      type="image/svg+xml"
    />
  </head>

  <body>
    <main>
      <header class="logo-area">
        <img
          class="logo-symbol"
          src="/logo/casane_logo_only.svg"
          alt=""
        />

        <img
          class="logo-text"
          src="/logo/casane_logo_text.svg"
          alt="casane by Daisuke Takakura"
        />

        <p class="status">
          under reconstruction
        </p>
      </header>

      <div
        class="separator separator-main"
        aria-hidden="true"
      >
        ∵
      </div>

      <nav
        class="links"
        aria-label="External links"
      >
        <div class="social">
          <a
            href={instagramWorks}
            target="_blank"
            rel="noopener noreferrer"
          >
            Instagram / works
          </a>

          <a
            href={instagramDaily}
            target="_blank"
            rel="noopener noreferrer"
          >
            Instagram / daily
          </a>

          <a
            href={xUrl}
            target="_blank"
            rel="noopener noreferrer"
          >
            X
          </a>
        </div>

        <div
          class="separator"
          aria-hidden="true"
        >
          ・
        </div>

        <div class="portfolio">
          <a
            href={portfolioUrl}
            target="_blank"
            rel="noopener noreferrer"
          >
            Portfolio
          </a>
        </div>

        <div
          class="separator"
          aria-hidden="true"
        >
          ・
        </div>

        <div class="contact">
          <a href={`mailto:${email}`}>
            {email}
          </a>
        </div>
      </nav>
    </main>
  </body>
</html>

<style>
  :global(*) {
    box-sizing: border-box;
  }

  :global(html) {
    background: #fff;
  }

  :global(body) {
    margin: 0;
    background: #fff;
    color: #111;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  main {
    display: flex;
    min-height: 100svh;
    padding: 5rem 2rem;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
  }

  .logo-area {
    display: flex;
    width: 100%;
    flex-direction: column;
    align-items: center;
  }

  .logo-symbol {
    display: block;
    width: 94px;
    height: auto;
  }

  .logo-text {
    display: block;
    width: 420px;
    max-width: 90vw;
    height: auto;
    margin-top: 1.4rem;
  }

  .status {
    margin: 3.2rem 0 0;
    color: #999;
    font-family:
      "Helvetica Neue",
      Helvetica,
      Arial,
      sans-serif;
    font-size: 0.82rem;
    font-style: normal;
    font-weight: 300;
    letter-spacing: 0.02em;
    line-height: 1.5;
  }

  .separator {
    margin-top: 3rem;
    color: #111;
    font-family:
      "Helvetica Neue",
      Helvetica,
      Arial,
      sans-serif;
    font-size: 0.9rem;
    font-weight: 300;
    line-height: 1;
  }

  .separator-main {
    margin-top: 3.2rem;
    font-size: 1rem;
  }

  .links {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .social {
    display: flex;
    margin-top: 3rem;
    flex-direction: column;
    align-items: center;
    gap: 1.2rem;
  }

  .portfolio,
  .contact {
    margin-top: 3rem;
  }

  a {
    color: #111;
    font-family: "din-condensed", sans-serif;
    font-size: 1rem;
    font-style: normal;
    font-weight: 300;
    letter-spacing: 0.12em;
    line-height: 1.4;
    text-decoration: none;
    transition: opacity 0.25s ease;
  }

  a:hover {
    opacity: 0.6;
  }

  a:focus-visible {
    outline: 1px solid currentColor;
    outline-offset: 0.4rem;
  }

  @media (max-width: 700px) {
    main {
      justify-content: flex-start;
      padding-top: 13svh;
      padding-right: 1.5rem;
      padding-bottom: 4rem;
      padding-left: 1.5rem;
    }

    .logo-symbol {
      width: 86px;
    }

    .logo-text {
      width: 290px;
      max-width: 88vw;
      margin-top: 1.5rem;
    }

    .status {
      margin-top: 3rem;
    }

    .separator-main {
      margin-top: 3rem;
    }

    .social {
      margin-top: 3rem;
    }

    .separator,
    .portfolio,
    .contact {
      margin-top: 2.8rem;
    }

    a {
      font-size: 0.95rem;
    }
  }
</style>