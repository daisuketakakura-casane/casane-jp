<style>
  :global(*) {
    box-sizing: border-box;
  }

  :global(html) {
    background: #fff;
  }

  :global(body) {
    margin: 0;
    background: #fff;
    color: #111;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  main {
    min-height: 100svh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 5rem 2rem;
    text-align: center;
  }

  header {
    display: flex;
    flex-direction: column;
    align-items: center;
    width: 100%;
  }

  .logo-group {
    display: flex;
    flex-direction: column;
    align-items: center;
    width: 100%;
  }

  .logo-symbol {
    display: block;
    width: 60px;
    height: auto;
  }

  .logo-text {
    display: block;
    width: 410px;
    max-width: 90vw;
    height: auto;
    margin-top: 1.2rem;
  }

  p {
    margin: 1.2rem 0 0;
    color: #999;
    font-family: "Helvetica Neue", Helvetica, Arial, sans-serif;
    font-size: 0.82rem;
    font-style: normal;
    font-weight: 300;
    letter-spacing: 0.02em;
    line-height: 1.5;
  }

  .main-separator {
    margin-top: 5.6rem;
    font-family: "Helvetica Neue", Helvetica, Arial, sans-serif;
    font-size: 0.9rem;
    font-weight: 300;
    line-height: 1;
  }

  .links {
    display: flex;
    flex-direction: column;
    align-items: center;
    margin-top: 3.5rem;
  }

  .social {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.2rem;
  }

  .separator {
    margin-top: 3.5rem;
    font-family: "Helvetica Neue", Helvetica, Arial, sans-serif;
    font-size: 0.9rem;
    font-weight: 300;
    line-height: 1;
  }

  .portfolio {
    margin-top: 3.5rem;
  }

  .contact {
    margin-top: 3.5rem;
  }

  a {
    color: #111;
    font-family: "din-condensed", sans-serif;
    font-size: 1rem;
    font-style: normal;
    font-weight: 300;
    letter-spacing: 0.12em;
    line-height: 1.4;
    text-decoration: none;
    transition: opacity 0.25s ease;
  }

  a:hover {
    opacity: 0.6;
  }

  a:focus-visible {
    outline: 1px solid currentColor;
    outline-offset: 0.4rem;
  }

  @media (max-width: 700px) {
    main {
      justify-content: flex-start;
      padding-top: 9svh;
      padding-bottom: 4rem;
    }

    .logo-symbol {
      width: 60px;
    }

    .logo-text {
      width: 290px;
      max-width: 88vw;
      height: auto;
      margin-top: 1.2rem;
    }

    .main-separator {
      margin-top: 4rem;
    }

    .links {
      margin-top: 3rem;
    }

    .separator,
    .portfolio,
    .contact {
      margin-top: 3rem;
    }

    a {
      font-size: 0.95rem;
    }
  }
