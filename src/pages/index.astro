---
const instagramWorks = "https://www.instagram.com/daisuke_takakura/";
const instagramDaily = "https://www.instagram.com/daisuke_takakura_daily/";
const xUrl = "https://x.com/schrodinger678";
const portfolioUrl = "ここにPortfolio PDFのURL";
const email = "takakura@casane.jp";
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />

    <meta
      name="viewport"
      content="width=device-width, initial-scale=1.0"
    />

    <meta
      name="description"
      content="casane by Daisuke Takakura"
    />

    <title>casane by Daisuke Takakura</title>
  </head>

  <body>
    <main>
      <header class="logo-area">
        <img
          class="logo-symbol"
          src="/casane_logo_only.svg"
          alt=""
        />

        <img
          class="logo-text"
          src="/casane_logo_text.svg"
          alt="casane by Daisuke Takakura"
        />
      </header>

      <p class="status">under reconstruction</p>

      <div class="symbol symbol-large" aria-hidden="true">
        ∵
      </div>

      <nav class="social-links" aria-label="Social media">
        <a
          href={instagramWorks}
          target="_blank"
          rel="noopener noreferrer"
        >
          Instagram / works
        </a>

        <a
          href={instagramDaily}
          target="_blank"
          rel="noopener noreferrer"
        >
          Instagram / daily
        </a>

        <a
          href={xUrl}
          target="_blank"
          rel="noopener noreferrer"
        >
          X
        </a>
      </nav>

      <div class="symbol" aria-hidden="true">
        ・
      </div>

      <div class="single-link">
        <a
          href={portfolioUrl}
          target="_blank"
          rel="noopener noreferrer"
        >
          Portfolio
        </a>
      </div>

      <div class="symbol" aria-hidden="true">
        ・
      </div>

      <div class="single-link">
        <a href={`mailto:${email}`}>
          {email}
        </a>
      </div>
    </main>
  </body>
</html>

<style>
  :global(*) {
    box-sizing: border-box;
  }

  :global(html) {
    margin: 0;
    padding: 0;
    background: #fff;
  }

  :global(body) {
    margin: 0;
    min-width: 320px;
    min-height: 100svh;
    background: #fff;
    color: #000;
    font-family: "din-condensed", "Arial Narrow", Arial, sans-serif;
    font-weight: 400;
  }

  main {
    display: flex;
    min-height: 100svh;
    padding: 4rem 2rem;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
  }

  .logo-area {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .logo-symbol {
    display: block;
    width: 92px;
    height: auto;
  }

  .logo-text {
    display: block;
    width: 420px;
    max-width: 85vw;
    height: auto;
    margin-top: 1.4rem;
  }

  .status {
    margin: 3.5rem 0 0;
    font-size: 1rem;
    line-height: 1;
  }

  .symbol {
    margin-top: 2.8rem;
    font-family: Arial, sans-serif;
    font-size: 0.9rem;
    line-height: 1;
  }

  .symbol-large {
    margin-top: 3rem;
    font-size: 1rem;
  }

  .social-links {
    display: flex;
    margin-top: 2.8rem;
    flex-direction: column;
    align-items: center;
    gap: 0.35rem;
  }

  .single-link {
    margin-top: 2.8rem;
  }

  a {
    color: inherit;
    font-size: 1rem;
    line-height: 1.25;
    text-decoration: none;
  }

  a:hover {
    opacity: 0.55;
  }

  a:focus-visible {
    outline: 1px solid currentColor;
    outline-offset: 4px;
  }

  @media (max-width: 700px) {
    main {
      justify-content: flex-start;
      padding-top: 13svh;
      padding-right: 1.5rem;
      padding-bottom: 4rem;
      padding-left: 1.5rem;
    }

    .logo-symbol {
      width: 86px;
    }

    .logo-text {
      width: 290px;
      max-width: 88vw;
      margin-top: 1.5rem;
    }

    .status {
      margin-top: 3.2rem;
    }

    .symbol-large {
      margin-top: 3rem;
    }

    .social-links {
      margin-top: 2.8rem;
    }

    .symbol,
    .single-link {
      margin-top: 2.7rem;
    }

    a,
    .status {
      font-size: 0.95rem;
    }
  }
</style>